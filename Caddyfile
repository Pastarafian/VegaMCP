mail.vegajournal.cc {
	root * /var/www/snappymail
	php_fastcgi unix//var/run/php/php8.3-fpm.sock
	file_server

	@data {
		path /data/*
	}
	respond @data 403

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	log {
		output file /var/log/caddy/snappymail.log
	}
}

http://vegaclaw.vegatech.online, http://claw.vegatech.online, http://claw.vegatech {
	# Auth check: accept either vegaclaw_auth OR vegatech_auth cookie
	@unauth {
		not header Cookie *vegaclaw_auth=*
		not header Cookie *vegatech_auth=*
		not path / /api/* /ide/* /static/* /vscode/* /stable/* /snapshot /vnc/* /websockify
	}
	respond @unauth 401 {
		body "Unauthorized - Please login at the dashboard root."
	}

	handle /stream {
		reverse_proxy localhost:4282 {
			flush_interval -1
		}
	}

	# Code-server IDE - use handle_path to auto-strip /ide prefix
	handle_path /ide/* {
		reverse_proxy localhost:8787
	}

	# Code-server internal assets (CSS/JS/fonts)
	handle /static/* {
		reverse_proxy localhost:8787
	}

	handle /vscode/* {
		reverse_proxy localhost:8787
	}

	handle /stable/* {
		reverse_proxy localhost:8787
	}

	handle /ollama/* {
		reverse_proxy localhost:11434
	}

	# noVNC WebSocket VPS Console (Cloudflare WebSocket-compatible)
	handle_path /vnc/* {
		reverse_proxy localhost:6080
	}

	handle /websockify {
		reverse_proxy localhost:6080
	}

	# Default fallback to Command Centre
	handle {
		reverse_proxy localhost:8585
	}

	log {
		output file /var/log/caddy/vegaclaw.log
	}
}
